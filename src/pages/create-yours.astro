---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Commission a Build | Durrant Guitars"
    description="Start a conversation about building your custom, handcrafted dream guitar."
>
    <div class="bg-background pt-32 pb-24">
        <div class="container mx-auto px-4 max-w-4xl">
            <h1
                class="font-serif text-5xl md:text-6xl text-white mb-6 text-center"
            >
                Commission a Build
            </h1>
            <p
                class="text-gray-400 text-center max-w-2xl mx-auto text-lg mb-16 font-light"
            >
                Ready to create an instrument tailored specifically to your
                voice? Fill out the form below to start the conversation with
                Tom.
            </p>

            <div
                class="bg-surface p-8 md:p-12 rounded-sm border border-white/5 shadow-2xl reveal delay-100"
            >
                <form
                    action="https://formsubmit.co/Tom.e.durrant@gmail.com"
                    method="POST"
                    enctype="multipart/form-data"
                    class="space-y-8"
                    id="buildForm"
                >
                    <!-- FormSubmit Configuration -->
                    <input
                        type="hidden"
                        name="_subject"
                        value="New Custom Build Inquiry — Durrant Guitars"
                    />
                    <input type="hidden" name="_template" value="table" />
                    <input type="hidden" name="_captcha" value="false" />
                    <input type="text" name="_honey" style="display:none" />

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <!-- Contact Info -->
                        <div class="space-y-6">
                            <h3
                                class="text-xs uppercase tracking-[0.2em] text-gray-400 border-b border-white/10 pb-2"
                            >
                                Your Information
                            </h3>

                            <div>
                                <label
                                    for="name"
                                    class="block text-sm font-medium text-gray-300 mb-2"
                                    >Name</label
                                >
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    required
                                    class="w-full bg-surface-light border border-white/10 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/30 transition-colors"
                                />
                            </div>

                            <div>
                                <label
                                    for="email"
                                    class="block text-sm font-medium text-gray-300 mb-2"
                                    >Email</label
                                >
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    class="w-full bg-surface-light border border-white/10 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/30 transition-colors"
                                />
                            </div>

                            <div>
                                <label
                                    for="phone"
                                    class="block text-sm font-medium text-gray-300 mb-2"
                                    >Phone (Optional)</label
                                >
                                <input
                                    type="tel"
                                    id="phone"
                                    name="phone"
                                    class="w-full bg-surface-light border border-white/10 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/30 transition-colors"
                                />
                            </div>
                        </div>

                        <!-- Build Details -->
                        <div class="space-y-6">
                            <h3
                                class="text-xs uppercase tracking-[0.2em] text-gray-400 border-b border-white/10 pb-2"
                            >
                                Build Details
                            </h3>

                            <div>
                                <label
                                    for="baseModel"
                                    class="block text-sm font-medium text-gray-300 mb-2"
                                    >Base Model</label
                                >
                                <select
                                    id="baseModel"
                                    name="baseModel"
                                    class="w-full bg-surface-light border border-white/10 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/30 transition-colors appearance-none"
                                    required
                                >
                                    <option value="" disabled selected
                                        >Select a model...</option
                                    >
                                    <option value="Charlatan"
                                        >The Charlatan (SG Style)</option
                                    >
                                    <option value="Con Artist"
                                        >The Con Artist (Single Cut)</option
                                    >
                                    <option value="Grifter"
                                        >The Grifter (Tele Style)</option
                                    >
                                    <option value="Swindler"
                                        >The Swindler (S-Style)</option
                                    >
                                    <option value="Racketeer"
                                        >The Racketeer (Offset)</option
                                    >
                                    <option value="Other"
                                        >Other / Fully Custom</option
                                    >
                                </select>
                            </div>

                            <div>
                                <label
                                    for="budget"
                                    class="block text-sm font-medium text-gray-300 mb-2"
                                    >Estimated Budget</label
                                >
                                <select
                                    id="budget"
                                    name="budget"
                                    class="w-full bg-surface-light border border-white/10 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/30 transition-colors appearance-none"
                                >
                                    <option value="$1,800 - $2,500"
                                        >$1,800 - $2,500 (Standard Tier)</option
                                    >
                                    <option value="$2,500 - $3,500"
                                        >$2,500 - $3,500 (Premium Woods & Specs)</option
                                    >
                                    <option value="$3,500+"
                                        >$3,500+ (Masterbuild)</option
                                    >
                                </select>
                            </div>

                            <div>
                                <label
                                    for="reference_images"
                                    class="block text-sm font-medium text-gray-300 mb-2"
                                    >Reference Images (Optional)</label
                                >
                                <input
                                    type="file"
                                    id="reference_images"
                                    name="reference_images"
                                    accept="image/*"
                                    multiple
                                    class="w-full bg-surface-light border border-white/10 rounded-sm px-4 py-2 text-white text-sm file:mr-4 file:py-2 file:px-4 file:rounded-sm file:border-0 file:text-xs file:font-semibold file:bg-white file:text-black hover:file:bg-gray-200 transition-colors"
                                />
                            </div>
                        </div>
                    </div>

                    <div class="mt-8 space-y-6">
                        <h3
                            class="text-xs uppercase tracking-[0.2em] text-gray-400 border-b border-white/10 pb-2"
                        >
                            Your Vision
                        </h3>

                        <div>
                            <label
                                for="vision"
                                class="block text-sm font-medium text-gray-300 mb-2"
                                >Describe what you are looking for.</label
                            >
                            <p class="text-xs text-gray-500 mb-3 font-light">
                                Wood choices, pickup configurations, neck
                                profiles, finishes, or just the overall vibe.
                            </p>
                            <textarea
                                id="vision"
                                name="vision"
                                rows="6"
                                required
                                class="w-full bg-surface-light border border-white/10 rounded-sm px-4 py-3 text-white focus:outline-none focus:border-white/30 focus:ring-1 focus:ring-white/30 transition-colors resize-y"
                            ></textarea>
                        </div>
                    </div>

                    <div class="pt-8 border-t border-white/10 text-center">
                        <button
                            type="submit"
                            class="btn btn-primary w-full md:w-auto px-12 uppercase tracking-widest text-sm font-semibold"
                        >
                            Submit Inquiry
                        </button>
                        <p class="text-xs text-gray-500 mt-4 font-light">
                            Tom will review your inquiry and get back to you
                            within 48 hours to discuss scheduling a
                            consultation.
                        </p>
                    </div>

                    <div id="result" class="hidden text-center mt-4 text-sm">
                    </div>
                </form>
            </div>
        </div>
    </div>
</Layout>

<script>
    // Logic to pre-select a model if 'model' parameter is in the URL
    document.addEventListener("DOMContentLoaded", () => {
        const params = new URLSearchParams(window.location.search);
        const modelParam = params.get("model");

        if (modelParam) {
            const select = document.getElementById(
                "baseModel",
            ) as HTMLSelectElement;
            const options = Array.from(select.options);

            // Find matching option (case insensitive, partial match)
            const match = options.find(
                (opt) =>
                    opt.value
                        .toLowerCase()
                        .includes(modelParam.toLowerCase().replace("-", " ")) ||
                    modelParam
                        .toLowerCase()
                        .includes(opt.value.toLowerCase().replace(" ", "-")),
            );

            if (match) {
                match.selected = true;
            }
        }

        // Handle form submission via fetch to show success message without redirecting
        const form = document.getElementById("buildForm") as HTMLFormElement;
        const result = document.getElementById("result");

        if (form && result) {
            form.addEventListener("submit", function (e) {
                e.preventDefault();
                const formData = new FormData(form);

                result.innerHTML = "Sending...";
                result.className =
                    "text-center mt-4 text-sm text-gray-400 block";

                fetch("https://formsubmit.co/ajax/Tom.e.durrant@gmail.com", {
                    method: "POST",
                    body: formData,
                    headers: {
                        Accept: "application/json",
                    },
                })
                    .then(async (response) => {
                        let json = await response.json();
                        if (response.status == 200 && json.success) {
                            result.innerHTML =
                                "Inquiry sent successfully! Tom will be in contact.";
                            result.className =
                                "text-center mt-4 text-sm text-green-400 block";
                            form.reset();
                        } else {
                            console.log(response);
                            result.innerHTML =
                                json.message || "Something went wrong.";
                            result.className =
                                "text-center mt-4 text-sm text-red-400 block";
                        }
                    })
                    .catch((error) => {
                        console.log(error);
                        result.innerHTML = "Something went wrong!";
                        result.className =
                            "text-center mt-4 text-sm text-red-400 block";
                    })
                    .then(function () {
                        setTimeout(() => {
                            result.style.display = "none";
                            setTimeout(() => {
                                result.style.display = "";
                                result.className = "hidden";
                            }, 500);
                        }, 5000);
                    });
            });
        }
    });
</script>
