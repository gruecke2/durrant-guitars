---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";

const catalog = await getCollection("catalog");
---

<Layout
    title="Guitar Models"
    description="Explore the base models that form the foundation of every Durrant custom guitar."
>
    <div class="bg-background pt-32 pb-20">
        <div class="container mx-auto px-4 max-w-5xl">
            <h1
                class="font-serif text-5xl md:text-6xl text-white mb-6 text-center"
            >
                The Models
            </h1>
            <p
                class="text-gray-400 text-center max-w-2xl mx-auto text-lg mb-20 font-light"
            >
                Our foundation. Every Durrant begins as one of these classic
                silhouettes, tailored to your distinct playing style.
            </p>

            <div class="space-y-24">
                {
                    catalog.map((model, index) => (
                        <div
                            class={`flex flex-col ${index % 2 !== 0 ? "md:flex-row-reverse" : "md:flex-row"} gap-12 items-center reveal delay-${((index % 3) + 1) * 100}`}
                        >
                            <div class="w-full md:w-1/2 aspect-square relative bg-surface-light group overflow-hidden rounded-sm">
                                <Picture
                                    src={model.data.images[0]}
                                    alt={model.data.name}
                                    widths={[400, 600, 800]}
                                    sizes="(max-width: 768px) 100vw, 50vw"
                                    formats={["avif", "webp"]}
                                    class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                                />
                            </div>
                            <div class="w-full md:w-1/2 space-y-6">
                                <div class="flex items-center gap-4 mb-2">
                                    <span class="bg-surface px-3 py-1 text-xs uppercase tracking-widest text-gray-300 font-semibold">
                                        {model.data.style}
                                    </span>
                                    <span class="text-xs uppercase tracking-[0.2em] text-gray-500 border-l border-white/20 pl-4">
                                        {model.data.tagline}
                                    </span>
                                </div>
                                <h2 class="font-serif text-4xl text-white">
                                    {model.data.name}
                                </h2>
                                <p class="text-gray-400 leading-relaxed font-light">
                                    {model.data.description}
                                </p>

                                <div class="pt-6 mt-6 border-t border-white/10 flex items-center justify-between">
                                    <div class="flex flex-col">
                                        <span class="text-xs text-gray-500 uppercase tracking-widest mb-1">
                                            Starts at
                                        </span>
                                        <span class="text-xl text-white font-medium">
                                            $
                                            {model.data.startingPrice.toLocaleString()}
                                        </span>
                                    </div>
                                    <a
                                        href={`/catalog/${model.data.slug}`}
                                        class="btn btn-outline text-xs tracking-widest uppercase py-2 px-6"
                                    >
                                        View Specs
                                    </a>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</Layout>
