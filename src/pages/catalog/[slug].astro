---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";

export async function getStaticPaths() {
    const catalog = await getCollection("catalog");
    return catalog.map((model) => ({
        params: { slug: model.data.slug },
        props: { model },
    }));
}

const { model } = Astro.props;
---

<Layout
    title={`${model.data.name} | Durrant Guitars`}
    description={model.data.description}
>
    <div class="bg-background pt-32 pb-20">
        <div class="container mx-auto px-4 max-w-6xl">
            <!-- Header -->
            <div
                class="mb-12 border-b border-white/10 pb-12 text-center md:text-left"
            >
                <div
                    class="flex flex-col md:flex-row items-center justify-between gap-6"
                >
                    <div>
                        <span
                            class="text-xs uppercase tracking-[0.2em] text-gray-400 mb-4 block"
                            >{model.data.style} Style</span
                        >
                        <h1
                            class="font-serif text-5xl md:text-6xl text-white mb-4"
                        >
                            {model.data.name}
                        </h1>
                        <p
                            class="text-gray-300 text-lg md:text-xl font-light italic max-w-2xl"
                        >
                            {model.data.tagline}
                        </p>
                    </div>
                    <div
                        class="mt-6 md:mt-0 flex flex-col items-center md:items-end p-6 bg-surface rounded-sm border border-white/5"
                    >
                        <span
                            class="text-xs uppercase tracking-widest text-gray-400 mb-2"
                            >Base Build Starting At</span
                        >
                        <span class="text-3xl text-white font-medium mb-4"
                            >${model.data.startingPrice.toLocaleString()}</span
                        >
                        <a
                            href={`/create-yours?model=${model.data.slug}`}
                            class="btn btn-primary text-xs uppercase tracking-widest"
                        >
                            Start Your Build
                        </a>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                <!-- Images Column -->
                <div class="lg:col-span-7 space-y-6">
                    {
                        model.data.images.map((img, index) => (
                            <div class="bg-surface-light rounded-sm overflow-hidden aspect-[4/3]">
                                <Picture
                                    src={img}
                                    alt={`${model.data.name} image ${index + 1}`}
                                    widths={[600, 900, 1200]}
                                    sizes="(max-width: 1024px) 100vw, 58vw"
                                    formats={["avif", "webp"]}
                                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                                    loading={index === 0 ? "eager" : "lazy"}
                                />
                            </div>
                        ))
                    }
                </div>

                <!-- Info Column -->
                <div class="lg:col-span-5 relative">
                    <div class="sticky top-32 space-y-12">
                        <div>
                            <h3
                                class="text-xs uppercase tracking-[0.2em] text-gray-400 mb-6 border-b border-white/10 pb-4"
                            >
                                The Story
                            </h3>
                            <p class="text-gray-300 leading-relaxed font-light">
                                {model.data.description}
                            </p>
                        </div>

                        <div>
                            <h3
                                class="text-xs uppercase tracking-[0.2em] text-gray-400 mb-6 border-b border-white/10 pb-4"
                            >
                                Standard Specifications
                            </h3>
                            <ul class="space-y-4">
                                {
                                    Object.entries(model.data.specs).map(
                                        ([key, value]) => (
                                            <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-4 border-b border-white/5 pb-4 last:border-0 last:pb-0">
                                                <span class="text-gray-500 uppercase tracking-wider text-xs font-semibold w-1/3 pt-1">
                                                    {key}
                                                </span>
                                                <span class="text-gray-200 text-sm w-2/3 leading-relaxed">
                                                    {value}
                                                </span>
                                            </li>
                                        ),
                                    )
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>
