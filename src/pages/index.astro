---
import Layout from "../layouts/Layout.astro";
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";
import heroImage from "../assets/images/site/Durrant Head Stock Photos/headstock_closeup-front-dark_01.jpg";
import secondaryImage from "../assets/images/site/catalog/racketeer/racketeer_front-full_01.jpg";
import thirdImage from "../assets/images/site/catalog/con-artist/con-artist_closeup-fretboard_01.jpg";
import tomPhoto from "../assets/images/site/Tom Photos/tom_portrait-studio_01.jpg";

const testimonials = (await getCollection("testimonials")).sort(
    (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
);
---

<Layout title="Custom Handcrafted Guitars">
    <!-- Hero Section -->
    <section id="hero-section" class="relative min-h-[90vh] bg-black flex items-center justify-center overflow-hidden">
        <!-- Image Container -->
        <div class="absolute inset-0 z-0 bg-black">
            <Picture
                src={heroImage}
                alt="Custom Durrant Guitar"
                widths={[800, 1200, 1600, 2400]}
                sizes="100vw"
                formats={["avif", "webp"]}
                class="w-full h-full object-cover hero-img"
                loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-background/100 via-background/40 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-background/90 via-transparent to-background/30"></div>
        </div>

        <!-- Content Container -->
        <div class="relative z-10 container mx-auto text-center px-4 max-w-4xl pt-20">
            <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-6 animate-fade-in-up">
                Precision, <br /><span class="text-gray-300 italic">With Personality</span>
            </h1>
            <p class="text-lg md:text-xl text-gray-300 mb-10 tracking-wide font-light max-w-2xl mx-auto animate-fade-in-up" style="animation-delay: 100ms;">
                Authentic to you. What else even matters?
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-6 py-4 animate-fade-in-up" style="animation-delay: 200ms;">
                <a href="/catalog" class="btn btn-primary w-full sm:w-auto text-sm tracking-widest uppercase font-semibold">
                    Take a Peek
                </a>
                <a href="/create-yours" class="hero-cta-build w-full sm:w-auto">
                    Start Your Build
                </a>
            </div>
        </div>
    </section>

    <!-- Introduce the Craft -->
    <section class="py-32 bg-background relative z-10 text-center">
        <div class="container mx-auto px-4 max-w-3xl">
            <h2
                class="font-serif text-3xl md:text-5xl text-white mb-8 slide-in-left"
            >
                Just How You Like It, Baby
            </h2>
            <div
                class="w-16 h-[1px] bg-accent/50 mx-auto mb-8 slide-in-right delay-100"
            >
            </div>
            <p
                class="text-gray-400 text-lg md:text-xl leading-relaxed font-light slide-in-left delay-200"
            >
                It’s your guitar. It should be exactly what you want it to be. Keep it classy. Or don’t. IDGAF.
            </p>
        </div>
    </section>

    <!-- Featured Models -->
    <section class="py-24 bg-surface relative">
        <div class="container mx-auto px-4">
            <div
                class="flex flex-col md:flex-row justify-between items-end mb-16 slide-in-right"
            >
                <div>
                    <span
                        class="text-xs tracking-[0.2em] uppercase text-gray-400 mb-2 block"
                        >Take a Peek</span
                    >
                    <h2 class="font-serif text-4xl text-white">
                        Explore Models
                    </h2>
                </div>
                <a
                    href="/catalog"
                    class="group flex items-center gap-2 text-sm text-white uppercase tracking-wider font-semibold hover:text-gray-300 transition-colors mt-6 md:mt-0"
                >
                    View All Models
                    <span
                        class="transform group-hover:translate-x-1 transition-transform"
                        >→</span
                    >
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
                <!-- Featured Card 1 -->
                <a
                    href="/catalog/grifter"
                    class="group block relative overflow-hidden rounded-sm aspect-[4/5] md:aspect-square bg-surface-light slide-in-left delay-100"
                >
                    <Picture
                        src={heroImage}
                        alt="The Grifter"
                        widths={[400, 600, 800]}
                        sizes="(max-width: 768px) 100vw, 50vw"
                        formats={["avif", "webp"]}
                        class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"
                    >
                    </div>
                    <div class="absolute bottom-0 left-0 p-8 w-full">
                        <span
                            class="text-xs tracking-[0.2em] uppercase text-gray-400 mb-2 block border-l-2 border-accent pl-3"
                            >The Tele Style</span
                        >
                        <h3 class="font-serif text-3xl text-white mb-3">
                            The Grifter
                        </h3>
                        <p
                            class="text-gray-300 text-sm font-light opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-300"
                        >
                            The honest con. Classic punch with modernized
                            ergonomics.
                        </p>
                    </div>
                </a>

                <!-- Featured Card 2 -->
                <a
                    href="/catalog/racketeer"
                    class="group block relative overflow-hidden rounded-sm aspect-[4/5] md:aspect-square bg-surface-light slide-in-right delay-200"
                >
                    <Picture
                        src={secondaryImage}
                        alt="The Racketeer"
                        widths={[400, 600, 800]}
                        sizes="(max-width: 768px) 100vw, 50vw"
                        formats={["avif", "webp"]}
                        class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-105 transition-all duration-700"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"
                    >
                    </div>
                    <div class="absolute bottom-0 left-0 p-8 w-full">
                        <span
                            class="text-xs tracking-[0.2em] uppercase text-gray-400 mb-2 block border-l-2 border-accent pl-3"
                            >The Offset</span
                        >
                        <h3 class="font-serif text-3xl text-white mb-3">
                            The Racketeer
                        </h3>
                        <p
                            class="text-gray-300 text-sm font-light opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-300"
                        >
                            Smooth, sweeping lines. Deep, resonant tone.
                        </p>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <!-- Testimonial Section -->
    <section class="py-28 bg-background relative overflow-hidden">
        <div
            class="absolute inset-0 z-0 bg-noise opacity-20 mix-blend-overlay pointer-events-none"
        >
        </div>
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="text-center mb-16 slide-in-left">
                <span
                    class="text-xs tracking-[0.2em] uppercase text-gray-500 mb-3 block"
                    >The Tea</span
                >
                <h2 class="font-serif text-4xl md:text-5xl text-white">
                    In Their Own Words
                </h2>
            </div>

            <div
                class="testimonial-carousel relative overflow-hidden slide-in-left delay-100"
            >
                <div
                    class="testimonial-carousel__track flex transition-transform duration-700 ease-[cubic-bezier(0.4,0,0.2,1)]"
                >
                    {
                        testimonials.map((t, i) => (
                            <div class="testimonial-slide w-full flex-[0_0_100%] min-w-full px-2 md:px-4">
                                <div class="testimonial-card h-full">
                                    {t.data.photo && (
                                        <div class="testimonial-card__image-wrap">
                                            <Picture
                                                src={t.data.photo}
                                                alt={`${t.data.name} with a Durrant guitar`}
                                                widths={[400, 600]}
                                                sizes="(max-width: 768px) 100vw, 40vw"
                                                formats={["avif", "webp"]}
                                                class="testimonial-card__image"
                                            />
                                        </div>
                                    )}
                                    <div class="testimonial-card__content">
                                        <svg
                                            class="testimonial-card__quote-icon"
                                            viewBox="0 0 24 24"
                                            fill="currentColor"
                                            aria-hidden="true"
                                        >
                                            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" />
                                        </svg>
                                        <blockquote class="testimonial-card__text">
                                            {t.data.quote}
                                        </blockquote>
                                        <div class="testimonial-card__author">
                                            <span class="testimonial-card__name">
                                                {t.data.name}
                                            </span>
                                            {t.data.role && (
                                                <span class="testimonial-card__role">
                                                    {t.data.role}
                                                </span>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <div class="flex justify-center gap-3 mt-12 pb-4">
                    {
                        testimonials.map((_, i) => (
                            <button
                                class={`testimonial-dot w-2.5 h-2.5 rounded-full transition-all duration-300 ${i === 0 ? "bg-accent scale-110" : "bg-white/20 hover:bg-white/40"}`}
                                data-index={i}
                                aria-label={`Go to testimonial ${i + 1}`}
                            />
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Meet Tom -->
    <section class="py-28 bg-surface relative overflow-hidden">
        <div class="container mx-auto px-4 max-w-6xl">
            <div class="meet-tom-grid">
                <div class="meet-tom-grid__image slide-in-left">
                    <Picture
                        src={tomPhoto}
                        alt="Tom Durrant in his workshop"
                        widths={[400, 600, 800]}
                        sizes="(max-width: 768px) 100vw, 45vw"
                        formats={["avif", "webp"]}
                        class="w-full h-full object-cover rounded-sm"
                    />
                </div>
                <div class="meet-tom-grid__content slide-in-right delay-100">
                    <span
                        class="text-xs tracking-[0.2em] uppercase text-gray-500 mb-3 block"
                        >Meet Tom Durrant</span
                    >
                    <h2 class="font-serif text-4xl md:text-5xl text-white mb-6">
                        This is Tom
                    </h2>
                    <div class="w-12 h-[1px] bg-accent/50 mb-6"></div>
                    <p
                        class="text-gray-400 text-lg leading-relaxed font-light mb-8"
                    >
                        I play music, build things, and don’t take direction well. That’s how I got here. I’m a masterbuilder and I masterbuild all over every guitar I make. 
                    </p>
                    <a
                        href="/about"
                        class="group inline-flex items-center gap-3 text-white text-sm uppercase tracking-widest font-semibold hover:text-accent transition-colors"
                    >
                        More About Tom and His Political Agenda
                        <span
                            class="transform group-hover:translate-x-2 transition-transform duration-300"
                            >→</span
                        >
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Philosophy Section -->
    <section class="py-32 relative bg-black overflow-hidden flex items-center justify-center text-center px-4">
        <div class="absolute inset-0 z-0 opacity-40">
            <div class="absolute inset-0 bg-gradient-to-tr from-[#b20404]/30 to-transparent"></div>
            <!-- noisy bg -->
            <div class="absolute inset-0 bg-noise opacity-30 mix-blend-overlay pointer-events-none"></div>
        </div>
        <div class="relative z-10 max-w-4xl mx-auto p-10 md:p-16 border border-white/10 bg-white/[0.02] backdrop-blur-md rounded-sm slide-in-left">
            <h2 class="font-serif text-3xl md:text-5xl text-white mb-6 tracking-wide">
                The Durrant Philosophy
            </h2>
            <div class="w-16 h-1 bg-accent mx-auto mb-10"></div>
            <p class="text-xl md:text-3xl font-light text-gray-300 leading-relaxed italic font-serif">
                "Your guitar shouldn’t fight you, it should beg for your touch. A great instrument lures you in, does things you never dreamed of, and makes you think it was your idea. You’ll soon realize your old guitars were faking it."
            </p>
        </div>
    </section>

    <!-- Available Now CTA -->
    <section class="py-32 relative overflow-hidden bg-background">
        <div
            class="absolute inset-0 z-0 bg-noise opacity-30 mix-blend-overlay pointer-events-none"
        >
        </div>
        <div class="absolute inset-0 z-0">
            <div
                class="absolute inset-0"
                style="background: radial-gradient(ellipse 80% 70% at 50% 50%, rgba(178, 4, 4, 0.18), transparent 70%);"
            >
            </div>
            <div
                class="absolute inset-0"
                style="background: radial-gradient(ellipse 120% 50% at 50% 110%, rgba(140, 20, 10, 0.2), transparent 60%);"
            >
            </div>
            <div
                class="absolute inset-0"
                style="background: radial-gradient(circle at 50% 45%, rgba(255, 255, 255, 0.02) 0%, transparent 40%);"
            >
            </div>
            <div
                class="absolute inset-0"
                style="background: radial-gradient(ellipse 100% 100% at 50% 50%, transparent 20%, rgba(10, 10, 10, 0.75) 100%);"
            >
            </div>
        </div>
        <div class="relative z-10 container mx-auto px-4 text-center">
            <div
                class="w-12 h-[2px] mx-auto mb-10 slide-in-left"
                style="background: linear-gradient(90deg, transparent, #b20404, transparent);"
            >
            </div>
            <h2
                class="font-serif text-4xl md:text-5xl text-white mb-6 slide-in-right"
            >
                No Patience? I’ve Got You
            </h2>
            <p
                class="text-gray-300 mb-10 max-w-xl mx-auto text-lg font-light slide-in-left delay-100"
            >
                These are done and ready to go.
            </p>
            <div class="slide-in-right delay-200 inline-block">
                <a
                    href="/available"
                    class="btn bg-white text-black hover:bg-gray-200 uppercase tracking-widest text-sm font-semibold px-8"
                >
                    Shop Available Inventory
                </a>
            </div>
        </div>
    </section>
</Layout>

<style>
    /* ── Hero Image Positioning & Layout ──────────────────── */
    .hero-img {
        /* Default constraint, typically mobile */
        object-position: center 30%;
    }

    /* Small laptops / Tablets */
    @media (min-width: 768px) and (max-height: 900px) {
        .hero-img {
            object-position: center 85%;
        }
    }

    /* 1080p and general desktop heights (1080px tall) */
    @media (min-width: 1024px) and (min-height: 900px) and (max-height: 1200px) {
        .hero-img {
            object-position: center 75%;
        }
    }

    /* 1440p and larger external monitors */
    @media (min-width: 1920px) {
        .hero-img {
            object-position: center 65%;
        }
    }

    /* Ultra-tall desktop monitors */
    @media (min-height: 1200px) {
        .hero-img {
            object-position: center 60%;
        }
    }

    /* ── Hero CTA — "Start Your Build" accent button ──── */
    .hero-cta-build {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 2rem;
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: white;
        background: linear-gradient(135deg, #b20404, #8a0303);
        border: 1px solid rgba(178, 4, 4, 0.6);
        border-radius: 2px;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
        box-shadow:
            0 0 20px rgba(178, 4, 4, 0.2),
            0 0 40px rgba(178, 4, 4, 0.1);
    }
    .hero-cta-build::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.1),
            transparent 50%
        );
        opacity: 0;
        transition: opacity 0.4s ease;
    }
    .hero-cta-build:hover {
        transform: translateY(-2px);
        box-shadow:
            0 0 30px rgba(178, 4, 4, 0.4),
            0 0 60px rgba(178, 4, 4, 0.2);
        border-color: rgba(178, 4, 4, 0.9);
    }
    .hero-cta-build:hover::before {
        opacity: 1;
    }

    /* ── Scroll Indicator (replaces "Discover" text) ──── */
    .scroll-indicator {
        width: 20px;
        height: 32px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 10px;
        position: relative;
    }
    .scroll-indicator__dot {
        width: 3px;
        height: 6px;
        background: rgba(255, 255, 255, 0.6);
        border-radius: 2px;
        position: absolute;
        top: 6px;
        left: 50%;
        transform: translateX(-50%);
        animation: scroll-pulse 2s ease-in-out infinite;
    }
    @keyframes scroll-pulse {
        0%,
        100% {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }
        50% {
            opacity: 0.3;
            transform: translateX(-50%) translateY(12px);
        }
    }

    /* ── Slide-In Animations ──────────────────────────── */
    .slide-in-left,
    .slide-in-right {
        opacity: 0;
        transition:
            opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1),
            transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
        will-change: opacity, transform;
    }
    .slide-in-left {
        transform: translateX(-40px);
    }
    .slide-in-right {
        transform: translateX(40px);
    }
    .slide-in-left.active,
    .slide-in-right.active {
        opacity: 1;
        transform: translateX(0);
    }

    /* ── Testimonial Card ─────────────────────────────── */
    .testimonial-card {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 4px;
        overflow: hidden;
    }
    @media (min-width: 768px) {
        .testimonial-card {
            flex-direction: row;
            min-height: 400px;
        }
    }
    .testimonial-card__image-wrap {
        flex: 0 0 40%;
        overflow: hidden;
        max-height: 400px;
    }
    @media (min-width: 768px) {
        .testimonial-card__image-wrap {
            max-height: none;
        }
    }
    .testimonial-card__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 20%;
    }
    .testimonial-card__content {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 2.5rem;
    }
    @media (min-width: 768px) {
        .testimonial-card__content {
            padding: 3rem;
        }
    }
    .testimonial-card__quote-icon {
        width: 2rem;
        height: 2rem;
        color: rgba(178, 4, 4, 0.4);
        margin-bottom: 1.5rem;
        flex-shrink: 0;
    }
    .testimonial-card__text {
        font-family: "Playfair Display", serif;
        font-size: 1.25rem;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.9);
        font-style: italic;
        font-weight: 400;
        margin-bottom: 2rem;
    }
    @media (min-width: 768px) {
        .testimonial-card__text {
            font-size: 1.4rem;
        }
    }
    .testimonial-card__author {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding-top: 1.5rem;
    }
    .testimonial-card__name {
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
    .testimonial-card__role {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.8rem;
        font-weight: 300;
    }

    /* ── Meet Tom Grid ────────────────────────────────── */
    .meet-tom-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: center;
    }
    @media (min-width: 768px) {
        .meet-tom-grid {
            grid-template-columns: 0.9fr 1fr;
            gap: 4rem;
        }
    }
    .meet-tom-grid__image {
        aspect-ratio: 4 / 5;
        overflow: hidden;
        border-radius: 2px;
    }
    @media (min-width: 768px) {
        .meet-tom-grid__image {
            aspect-ratio: 3 / 4;
        }
    }

    /* ── Shared Animations ────────────────────────────── */
    @keyframes fade-in-up {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation-name: fade-in-up;
        animation-duration: 0.8s;
        animation-timing-function: cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .bg-noise {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    }
</style>

<script>
    // ── Intersection Observer for slide-in animations ──
    document.addEventListener("DOMContentLoaded", () => {
        const slideObserver = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("active");
                        slideObserver.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.15, rootMargin: "0px" },
        );

        document
            .querySelectorAll(".slide-in-left, .slide-in-right")
            .forEach((el) => {
                slideObserver.observe(el);
            });

        // ── Testimonial Carousel ──
        const track = document.querySelector(
            ".testimonial-carousel__track",
        ) as HTMLElement;
        const dots = document.querySelectorAll(".testimonial-dot");
        let currentSlide = 0;
        let slideInterval: number;

        if (track && dots.length > 0) {
            const numSlides = dots.length;

            const goToSlide = (index: number) => {
                currentSlide = index;
                track.style.transform = `translateX(-${currentSlide * 100}%)`;

                dots.forEach((dot, i) => {
                    if (i === currentSlide) {
                        dot.classList.remove(
                            "bg-white/20",
                            "hover:bg-white/40",
                        );
                        dot.classList.add("bg-accent", "scale-110");
                    } else {
                        dot.classList.add("bg-white/20", "hover:bg-white/40");
                        dot.classList.remove("bg-accent", "scale-110");
                    }
                });
            };

            const nextSlide = () => {
                goToSlide((currentSlide + 1) % numSlides);
            };

            const startInterval = () => {
                slideInterval = window.setInterval(nextSlide, 7000); // 7s auto-rotate
            };

            const resetInterval = () => {
                window.clearInterval(slideInterval);
                startInterval();
            };

            dots.forEach((dot, i) => {
                dot.addEventListener("click", () => {
                    goToSlide(i);
                    resetInterval();
                });
            });

            startInterval();
        }

        // Hero Scroll Effect Removed.
    });
</script>
