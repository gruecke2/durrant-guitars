---
import Layout from "../../layouts/Layout.astro";
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
    .filter((p) => !p.data.draft)
    .sort(
        (a, b) =>
            new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
    );
---

<Layout
    title="Blog"
    description="Build diaries, shop updates, and stories from the bench."
>
    <section class="py-24 bg-background">
        <div class="container mx-auto px-4 max-w-4xl">
            <div class="text-center mb-16 reveal">
                <span
                    class="text-xs tracking-[0.2em] uppercase text-gray-500 mb-3 block"
                    >From the Bench</span
                >
                <h1 class="font-serif text-4xl md:text-6xl text-white mb-4">
                    Blog
                </h1>
                <p class="text-gray-400 text-lg font-light max-w-xl mx-auto">
                    Build diaries, shop updates, and the occasional rant about
                    tone woods.
                </p>
            </div>

            <div class="blog-list">
                {
                    posts.map((post) => (
                        <a href={`/blog/${post.id}`} class="blog-card reveal">
                            {post.data.coverImage && (
                                <div class="blog-card__image">
                                    <Picture
                                        src={post.data.coverImage}
                                        alt={post.data.title}
                                        widths={[400, 600, 800]}
                                        sizes="(max-width: 768px) 100vw, 50vw"
                                        formats={["avif", "webp"]}
                                        class="w-full h-full object-cover"
                                    />
                                </div>
                            )}
                            <div class="blog-card__content">
                                <time class="blog-card__date">
                                    {new Date(
                                        post.data.date,
                                    ).toLocaleDateString("en-US", {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    })}
                                </time>
                                <h2 class="blog-card__title">
                                    {post.data.title}
                                </h2>
                                <p class="blog-card__excerpt">
                                    {post.data.excerpt}
                                </p>
                                <span class="blog-card__read-more">
                                    Read More →
                                </span>
                            </div>
                        </a>
                    ))
                }
            </div>

            {
                posts.length === 0 && (
                    <p class="text-center text-gray-500 text-lg">
                        No posts yet. Check back soon.
                    </p>
                )
            }
        </div>
    </section>
</Layout>

<style>
    .blog-list {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .blog-card {
        display: flex;
        flex-direction: column;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 4px;
        overflow: hidden;
        text-decoration: none;
        transition: all 0.3s ease;
    }
    @media (min-width: 768px) {
        .blog-card {
            flex-direction: row;
        }
    }
    .blog-card:hover {
        border-color: rgba(255, 255, 255, 0.12);
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    }

    .blog-card__image {
        flex: 0 0 280px;
        max-height: 220px;
        overflow: hidden;
    }
    @media (min-width: 768px) {
        .blog-card__image {
            max-height: none;
        }
    }

    .blog-card__content {
        flex: 1;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .blog-card__date {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.35);
        margin-bottom: 0.75rem;
    }

    .blog-card__title {
        font-family: "Playfair Display", serif;
        font-size: 1.5rem;
        color: white;
        margin-bottom: 0.75rem;
        line-height: 1.3;
    }

    .blog-card__excerpt {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.95rem;
        font-weight: 300;
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .blog-card__read-more {
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: color 0.2s;
    }
    .blog-card:hover .blog-card__read-more {
        color: white;
    }
</style>
