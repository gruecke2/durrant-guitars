---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Picture } from 'astro:assets';

// Fetch gallery builds
const builds = await getCollection('gallery');

// Sort by date descending
const sortedBuilds = builds.sort((a, b) => {
    return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
});

// ── Workshop photos (masonry tiles) ─ managed via Keystatic ──
const workshopImages = import.meta.glob<{ default: ImageMetadata }>(
    '../assets/images/site/workshop/*.{jpg,jpeg,png}',
    { eager: true }
);

interface MasonryTile {
    image: ImageMetadata;
    alt: string;
    label: string;
}

const masonryTiles: MasonryTile[] = Object.entries(workshopImages).map(([path, mod]) => {
    const filename = path.split('/').pop()?.replace(/\.(jpg|jpeg|png)$/, '') || '';
    const label = filename
        .replace('build_', '')
        .replace(/_/g, ' ')
        .replace(/-/g, ' ')
        .replace(/\b\w/g, c => c.toUpperCase())
        .replace(/ 0\d$/, '');
    return { image: mod.default, alt: `Past build: ${label}`, label };
});
---

<Layout title="Gallery | Durrant Guitars" description="View our portfolio of custom handcrafted guitars — featured builds and the workshop archive.">
    <div class="bg-background pt-32 pb-24">
        <div class="container mx-auto px-4 max-w-7xl">
            <h1 class="font-serif text-5xl md:text-6xl text-white mb-6 text-center">The Gallery</h1>
            <p class="text-gray-400 text-center max-w-2xl mx-auto text-lg mb-20 font-light">
                Proof that I kinda know what I'm doing.
            </p>

            <!-- ═══ FEATURED BUILDS ═══════════════════════════════ -->
            <div class="space-y-28">
                {sortedBuilds.map((build, index) => (
                    <section class="reveal">
                        <!-- Build header -->
                        <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-white/10 pb-4">
                            <div>
                                <h2 class="font-serif text-3xl text-white mb-2">{build.data.title}</h2>
                                <p class="text-gray-400 font-light max-w-3xl">{build.data.description}</p>
                            </div>
                            {build.data.model && (
                                <a href={`/catalog/${build.data.model.toLowerCase().replace(' ', '-')}`} class="text-xs uppercase tracking-widest text-gray-500 hover:text-white transition-colors shrink-0">
                                    Base Model: {build.data.model}
                                </a>
                            )}
                        </div>
                        
                        <!-- Bento-style image grid -->
                        <div class={`gallery-grid gallery-grid--${Math.min(build.data.images.length, 4)}`}>
                            {build.data.images.map((img: any, i: number) => (
                                <button
                                    class={`gallery-item gallery-item--${i + 1} group`}
                                    data-gallery-index={index}
                                    data-image-index={i}
                                    data-full-src={img.src}
                                    data-full-width={img.width}
                                    data-full-height={img.height}
                                    type="button"
                                    aria-label={`View ${build.data.title} image ${i + 1}`}
                                >
                                    <Picture 
                                        src={img} 
                                        alt={`${build.data.title} image ${i + 1}`}
                                        widths={[400, 600, 900]}
                                        sizes={i === 0 ? "(max-width: 768px) 100vw, 60vw" : "(max-width: 768px) 50vw, 30vw"}
                                        formats={['avif', 'webp']}
                                        class="gallery-item__img"
                                        loading={index === 0 && i < 2 ? "eager" : "lazy"}
                                    />
                                    <div class="gallery-item__overlay">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9m11.25-5.25v4.5m0-4.5h-4.5m4.5 0L15 9m-11.25 11.25v-4.5m0 4.5h4.5m-4.5 0L9 15m11.25 5.25v-4.5m0 4.5h-4.5m4.5 0L15 15" />
                                        </svg>
                                    </div>
                                </button>
                            ))}
                        </div>
                    </section>
                ))}
            </div>

            <!-- ═══ MASONRY — FROM THE WORKSHOP ═══════════════════ -->
            {masonryTiles.length > 0 && (
                <section class="mt-36 reveal">
                    <div class="mb-12 text-center">
                        <span class="text-xs tracking-[0.2em] uppercase text-gray-500 mb-3 block">The Archive</span>
                        <h2 class="font-serif text-4xl md:text-5xl text-white mb-4">From the Workshop</h2>
                        <div class="w-16 h-[1px] bg-accent/50 mx-auto mb-6"></div>
                        <p class="text-gray-400 max-w-2xl mx-auto font-light text-lg">
                            Not every build gets a full feature. Here's a look at the one-offs, experiments, and happy accidents.
                        </p>
                    </div>

                    <div class="masonry-grid">
                        {masonryTiles.map((tile, i) => (
                            <button
                                class="masonry-tile group"
                                data-gallery-index="masonry"
                                data-image-index={i}
                                data-full-src={tile.image.src}
                                data-full-width={tile.image.width}
                                data-full-height={tile.image.height}
                                type="button"
                                aria-label={`View ${tile.alt}`}
                            >
                                <Picture
                                    src={tile.image}
                                    alt={tile.alt}
                                    widths={[300, 500]}
                                    sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
                                    formats={['avif', 'webp']}
                                    class="masonry-tile__img"
                                    loading="lazy"
                                />
                                <div class="masonry-tile__overlay">
                                    <span class="masonry-tile__label">{tile.label}</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 masonry-tile__icon">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9m11.25-5.25v4.5m0-4.5h-4.5m4.5 0L15 9m-11.25 11.25v-4.5m0 4.5h4.5m-4.5 0L9 15m11.25 5.25v-4.5m0 4.5h-4.5m4.5 0L15 15" />
                                    </svg>
                                </div>
                            </button>
                        ))}
                    </div>
                </section>
            )}
            
            <div class="mt-32 text-center p-12 border border-white/5 bg-surface rounded-sm reveal">
                <h3 class="font-serif text-3xl text-white mb-4">Inspired?</h3>
                <p class="text-gray-400 max-w-xl mx-auto mb-8 font-light">Every build starts with a conversation. Let's build your dream instrument.</p>
                <a href="/create-yours" class="btn btn-primary px-8 uppercase tracking-widest text-xs font-semibold">Start the Process</a>
            </div>
        </div>
    </div>
</Layout>

<!-- Lightbox overlay (custom, no PhotoSwipe) -->
<div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="lightbox__close" aria-label="Close lightbox" id="lightbox-close">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>
    <!-- Counter -->
    <div class="lightbox__counter" id="lightbox-counter"></div>
    <!-- Navigation -->
    <button class="lightbox__nav lightbox__nav--prev" id="lightbox-prev" aria-label="Previous image">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
    </button>
    <button class="lightbox__nav lightbox__nav--next" id="lightbox-next" aria-label="Next image">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
    </button>
    <!-- Image container -->
    <div class="lightbox__image-wrap" id="lightbox-image-wrap">
        <img id="lightbox-img" class="lightbox__img" src="" alt="" />
    </div>
</div>

<style>
    /* ── Bento Grid Layouts ─────────────────────────────── */
    .gallery-grid {
        display: grid;
        gap: 0.5rem;
        grid-auto-rows: minmax(200px, 1fr);
    }

    /* 1 image: single full-width */
    .gallery-grid--1 {
        grid-template-columns: 1fr;
        grid-template-rows: minmax(300px, 500px);
    }

    /* 2 images: side by side */
    .gallery-grid--2 {
        grid-template-columns: 1.2fr 0.8fr;
        grid-template-rows: minmax(280px, 450px);
    }

    /* 3 images: hero left + 2 stacked right */
    .gallery-grid--3 {
        grid-template-columns: 1.3fr 0.7fr;
        grid-template-rows: repeat(2, minmax(200px, 280px));
    }
    .gallery-grid--3 .gallery-item--1 {
        grid-row: 1 / 3;
    }

    /* 4 images: hero left + 3 stacked right (or 2+1 if space) */
    .gallery-grid--4 {
        grid-template-columns: 1.4fr 0.6fr;
        grid-template-rows: repeat(3, minmax(140px, 200px));
    }
    .gallery-grid--4 .gallery-item--1 {
        grid-row: 1 / 4;
    }

    /* Mobile: stack everything */
    @media (max-width: 640px) {
        .gallery-grid--2,
        .gallery-grid--3,
        .gallery-grid--4 {
            grid-template-columns: 1fr;
            grid-template-rows: auto;
        }
        .gallery-grid--3 .gallery-item--1,
        .gallery-grid--4 .gallery-item--1 {
            grid-row: auto;
        }
        .gallery-item {
            aspect-ratio: 4 / 3;
        }
    }

    /* ── Gallery Item ───────────────────────────────────── */
    .gallery-item {
        position: relative;
        overflow: hidden;
        border-radius: 4px;
        cursor: pointer;
        border: none;
        padding: 0;
        background: #171717;
    }

    .gallery-item__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .gallery-item:hover .gallery-item__img {
        transform: scale(1.04);
    }

    .gallery-item__overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        opacity: 0;
        transition: all 0.3s ease;
    }

    .gallery-item:hover .gallery-item__overlay {
        background: rgba(0, 0, 0, 0.25);
        opacity: 1;
    }

    /* ── Masonry Grid ───────────────────────────────────── */
    .masonry-grid {
        columns: 2;
        column-gap: 0.75rem;
    }

    @media (min-width: 640px) {
        .masonry-grid {
            columns: 3;
        }
    }

    @media (min-width: 1024px) {
        .masonry-grid {
            columns: 4;
            column-gap: 1rem;
        }
    }

    .masonry-tile {
        position: relative;
        display: block;
        width: 100%;
        break-inside: avoid;
        margin-bottom: 0.75rem;
        overflow: hidden;
        border-radius: 6px;
        cursor: pointer;
        border: none;
        padding: 0;
        background: #171717;
        transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
                    box-shadow 0.4s ease;
    }

    @media (min-width: 1024px) {
        .masonry-tile {
            margin-bottom: 1rem;
        }
    }

    .masonry-tile:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5),
                    0 0 0 1px rgba(178, 4, 4, 0.15);
    }

    .masonry-tile__img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1),
                    filter 0.6s ease;
    }

    .masonry-tile:hover .masonry-tile__img {
        transform: scale(1.06);
    }

    .masonry-tile__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.75) 0%,
            rgba(0, 0, 0, 0.15) 40%,
            rgba(0, 0, 0, 0) 100%
        );
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-end;
        padding: 1rem;
        opacity: 0;
        transition: opacity 0.35s ease;
    }

    .masonry-tile:hover .masonry-tile__overlay {
        opacity: 1;
    }

    .masonry-tile__label {
        color: white;
        font-size: 0.7rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        line-height: 1.3;
        transform: translateY(8px);
        transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .masonry-tile:hover .masonry-tile__label {
        transform: translateY(0);
    }

    .masonry-tile__icon {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        color: rgba(255, 255, 255, 0.8);
        opacity: 0;
        transform: scale(0.8);
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .masonry-tile:hover .masonry-tile__icon {
        opacity: 1;
        transform: scale(1);
    }

    /* Stagger reveal for masonry tiles */
    .masonry-tile {
        opacity: 0;
        transform: translateY(24px);
        animation: masonry-reveal 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    @keyframes masonry-reveal {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Stagger each tile */
    .masonry-tile:nth-child(1)  { animation-delay: 0.05s; }
    .masonry-tile:nth-child(2)  { animation-delay: 0.10s; }
    .masonry-tile:nth-child(3)  { animation-delay: 0.15s; }
    .masonry-tile:nth-child(4)  { animation-delay: 0.20s; }
    .masonry-tile:nth-child(5)  { animation-delay: 0.25s; }
    .masonry-tile:nth-child(6)  { animation-delay: 0.30s; }
    .masonry-tile:nth-child(7)  { animation-delay: 0.35s; }
    .masonry-tile:nth-child(8)  { animation-delay: 0.40s; }
    .masonry-tile:nth-child(9)  { animation-delay: 0.45s; }
    .masonry-tile:nth-child(10) { animation-delay: 0.50s; }
    .masonry-tile:nth-child(11) { animation-delay: 0.55s; }
    .masonry-tile:nth-child(12) { animation-delay: 0.60s; }
    .masonry-tile:nth-child(13) { animation-delay: 0.65s; }
    .masonry-tile:nth-child(14) { animation-delay: 0.70s; }

    /* ── Lightbox ────────────────────────────────────────── */
    .lightbox {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0, 0, 0, 0);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, background 0.3s ease, visibility 0s 0.3s;
        -webkit-backdrop-filter: blur(0px);
        backdrop-filter: blur(0px);
    }

    .lightbox.is-active {
        opacity: 1;
        visibility: visible;
        background: rgba(0, 0, 0, 0.92);
        -webkit-backdrop-filter: blur(20px);
        backdrop-filter: blur(20px);
        transition: opacity 0.3s ease, background 0.3s ease, visibility 0s 0s;
    }

    .lightbox__close {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        color: rgba(255, 255, 255, 0.7);
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        border-radius: 50%;
        transition: color 0.2s, background 0.2s;
        z-index: 10;
    }
    .lightbox__close:hover {
        color: white;
        background: rgba(255, 255, 255, 0.1);
    }

    .lightbox__counter {
        position: absolute;
        top: 1.5rem;
        left: 1.5rem;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.8rem;
        font-variant-numeric: tabular-nums;
        letter-spacing: 0.05em;
        z-index: 10;
    }

    .lightbox__nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255, 255, 255, 0.5);
        background: none;
        border: none;
        cursor: pointer;
        padding: 1rem;
        transition: color 0.2s;
        z-index: 10;
    }
    .lightbox__nav:hover {
        color: white;
    }
    .lightbox__nav--prev { left: 0.5rem; }
    .lightbox__nav--next { right: 0.5rem; }

    .lightbox__image-wrap {
        max-width: 90vw;
        max-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lightbox__img {
        max-width: 100%;
        max-height: 85vh;
        object-fit: contain;
        border-radius: 2px;
        opacity: 0;
        transform: scale(0.96);
        transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .lightbox.is-active .lightbox__img {
        opacity: 1;
        transform: scale(1);
    }
</style>

<script>
    // ── Custom Gallery Lightbox ──────────────────────────
    const lightbox = document.getElementById('lightbox')!;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxClose = document.getElementById('lightbox-close')!;
    const lightboxPrev = document.getElementById('lightbox-prev')!;
    const lightboxNext = document.getElementById('lightbox-next')!;
    const lightboxCounter = document.getElementById('lightbox-counter')!;

    // Track current state
    let currentGalleryItems: HTMLElement[] = [];
    let currentIndex = 0;

    function openLightbox(galleryId: string, imageIndex: number) {
        // Collect all items in this gallery group
        currentGalleryItems = Array.from(
            document.querySelectorAll(`[data-gallery-index="${galleryId}"]`)
        ) as HTMLElement[];
        currentIndex = imageIndex;
        showImage();
        lightbox.classList.add('is-active');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }

    function showImage() {
        const item = currentGalleryItems[currentIndex];
        if (!item) return;

        const src = item.dataset.fullSrc || '';
        const alt = item.getAttribute('aria-label') || '';
        
        // Brief opacity dip for image swap
        lightboxImg.style.opacity = '0';
        lightboxImg.style.transform = 'scale(0.96)';

        // Preload then show
        const preload = new Image();
        preload.onload = () => {
            lightboxImg.src = src;
            lightboxImg.alt = alt;
            // Force reflow then animate in
            void lightboxImg.offsetWidth;
            lightboxImg.style.opacity = '1';
            lightboxImg.style.transform = 'scale(1)';
        };
        preload.src = src;

        // Update counter
        lightboxCounter.textContent = `${currentIndex + 1} / ${currentGalleryItems.length}`;

        // Toggle nav visibility
        lightboxPrev.style.display = currentGalleryItems.length > 1 ? '' : 'none';
        lightboxNext.style.display = currentGalleryItems.length > 1 ? '' : 'none';
    }

    function closeLightbox() {
        lightbox.classList.remove('is-active');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        // Delay clearing src so the fade-out animation plays
        setTimeout(() => {
            lightboxImg.src = '';
        }, 300);
    }

    function nextImage() {
        currentIndex = (currentIndex + 1) % currentGalleryItems.length;
        showImage();
    }

    function prevImage() {
        currentIndex = (currentIndex - 1 + currentGalleryItems.length) % currentGalleryItems.length;
        showImage();
    }

    // Click handlers on gallery items (bento grids)
    document.querySelectorAll('.gallery-item').forEach((item) => {
        item.addEventListener('click', () => {
            const galleryId = (item as HTMLElement).dataset.galleryIndex || '0';
            const imageIndex = parseInt((item as HTMLElement).dataset.imageIndex || '0');
            openLightbox(galleryId, imageIndex);
        });
    });

    // Click handlers on masonry tiles
    document.querySelectorAll('.masonry-tile').forEach((item) => {
        item.addEventListener('click', () => {
            const galleryId = (item as HTMLElement).dataset.galleryIndex || 'masonry';
            const imageIndex = parseInt((item as HTMLElement).dataset.imageIndex || '0');
            openLightbox(galleryId, imageIndex);
        });
    });

    // Lightbox controls
    lightboxClose.addEventListener('click', closeLightbox);
    lightboxPrev.addEventListener('click', prevImage);
    lightboxNext.addEventListener('click', nextImage);

    // Click backdrop to close
    lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox || (e.target as HTMLElement).id === 'lightbox-image-wrap') {
            closeLightbox();
        }
    });

    // Keyboard controls
    document.addEventListener('keydown', (e) => {
        if (!lightbox.classList.contains('is-active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowRight') nextImage();
        if (e.key === 'ArrowLeft') prevImage();
    });

    // ── Intersection Observer for masonry reveal ────────
    const masonryObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    (entry.target as HTMLElement).style.animationPlayState = 'running';
                    masonryObserver.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.1, rootMargin: '50px' }
    );

    document.querySelectorAll('.masonry-tile').forEach((tile) => {
        (tile as HTMLElement).style.animationPlayState = 'paused';
        masonryObserver.observe(tile);
    });
</script>
