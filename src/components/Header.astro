---
import logoSvgUrl from "../assets/images/logo/Durrant-Logo-Vector.svg?url";
import navData from "../content/navLinks.json";
---

<header id="site-header">
    <div class="header-inner">
        <!-- Logo (wordmark in SVG — no separate text) -->
        <a href="/" class="logo-link">
            <img
                src={logoSvgUrl}
                alt="Durrant Guitars"
                width="640"
                height="373"
                class="logo-img"
                decoding="async"
            />
        </a>

        <!-- Desktop Nav -->
        <nav class="desktop-nav">
            {
                navData.links
                    .filter((link) => link.isVisible)
                    .map((link) => (
                        <a href={link.href} class={link.isCta ? "cta-btn" : ""}>
                            {link.label}
                        </a>
                    ))
            }
        </nav>

        <!-- Hamburger / X button -->
        <button
            id="menu-toggle"
            class="menu-toggle"
            aria-label="Toggle menu"
            aria-expanded="false"
        >
            <span class="bar bar-top"></span>
            <span class="bar bar-mid"></span>
            <span class="bar bar-bot"></span>
        </button>
    </div>
</header>

<!-- Full-screen mobile nav overlay -->
<div id="mobile-overlay" class="mobile-overlay" aria-hidden="true">
    <nav class="mobile-nav">
        {
            navData.links
                .filter((link) => link.isVisible)
                .map((link, idx) => (
                    <a
                        href={link.href}
                        class={`mobile-link ${link.isCta ? "mobile-cta" : ""}`}
                        style={`--i:${idx}`}
                    >
                        {link.label}
                    </a>
                ))
        }
    </nav>
</div>

<style>
    /* ── Base header ─────────────────────────────────────────── */
    #site-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: rgba(10, 10, 10, 0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1280px;
        margin: 0 auto;
        padding: 0.5rem 1.5rem;
        min-height: 5.5rem; /* room for wide wordmark */
    }

    /* ── Logo ────────────────────────────────────────────────── */
    .logo-link {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        text-decoration: none;
        position: relative;
        z-index: 1001; /* stays above overlay */
    }

    .logo-img {
        display: block;
        width: auto;
        /* Wide SVG: drive size by height so width grows with aspect ratio (~1.71:1) */
        height: clamp(3.25rem, 9vw, 5.75rem);
        max-height: 5.75rem;
        max-width: min(calc(100vw - 4.75rem), 36rem);
        object-fit: contain;
    }

    @media (min-width: 768px) {
        .header-inner {
            min-height: 5.75rem;
            padding: 0.6rem 1.5rem;
        }

        .logo-img {
            height: clamp(3.75rem, 5.5vw, 6.25rem);
            max-height: 6.25rem;
            max-width: min(55vw, 40rem);
        }
    }

    @media (min-width: 1024px) {
        .logo-img {
            height: clamp(4rem, 4.25vw, 6.5rem);
            max-height: 6.5rem;
            max-width: 42rem;
        }
    }

    /* ── Desktop nav ─────────────────────────────────────────── */
    .desktop-nav {
        display: none;
        align-items: center;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .desktop-nav {
            display: flex;
        }
        .menu-toggle {
            display: none;
        }
    }

    .desktop-nav a {
        color: #aaa;
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: color 0.2s;
    }

    .desktop-nav a:hover {
        color: #fff;
    }

    .cta-btn {
        background: #fff;
        color: #000 !important;
        padding: 0.6rem 1.25rem;
        border-radius: 2px;
        font-weight: 600;
        transition: background 0.2s !important;
    }

    .cta-btn:hover {
        background: #e0e0e0 !important;
    }

    /* ── Hamburger button ────────────────────────────────────── */
    .menu-toggle {
        /* use position:relative + absolute bars so translateY math is exact */
        position: relative;
        z-index: 1001;
        width: 2rem;
        height: 2rem;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
    }

    .bar {
        display: block;
        position: absolute;
        left: 0;
        width: 22px;
        height: 1.5px;
        background: #fff;
        border-radius: 1px;
        transform-origin: center;
        /* single consistent transition on all bars */
        transition:
            transform 0.35s cubic-bezier(0.23, 1, 0.32, 1),
            opacity 0.2s ease;
    }

    /* place bars at exact pixel positions: top=7, mid=15, bot=23 (of 30px) */
    .bar-top {
        top: 7px;
    }
    .bar-mid {
        top: 15px;
    }
    .bar-bot {
        top: 23px;
    }

    /* ── Open state: bars morph to × ────────────────────────── */
    /* top + bot each move to the mid-point (15px) then rotate */
    .menu-toggle.is-open .bar-top {
        transform: translateY(8px) rotate(45deg);
    }
    .menu-toggle.is-open .bar-mid {
        opacity: 0;
        /* no scaleX — just fade, avoids sub-pixel rendering jitter */
    }
    .menu-toggle.is-open .bar-bot {
        transform: translateY(-8px) rotate(-45deg);
    }

    /* ── Mobile overlay — mobile only ───────────────────────── */
    .mobile-overlay {
        position: fixed;
        inset: 0;
        z-index: 999;
        background: #0a0a0a;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

        /* hidden state */
        clip-path: inset(0 0 100% 0);
        transition: clip-path 0.55s cubic-bezier(0.76, 0, 0.24, 1);
        pointer-events: none;
    }

    .mobile-overlay.is-open {
        clip-path: inset(0 0 0% 0);
        pointer-events: all;
    }

    /* never show on desktop, even if JS mishap triggers open() */
    @media (min-width: 768px) {
        .mobile-overlay {
            display: none !important;
        }
    }

    /* ── Mobile nav links ────────────────────────────────────── */
    .mobile-nav {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2.25rem;
        padding: 2rem;
    }

    .mobile-link {
        color: #fff;
        text-decoration: none;
        font-family: Georgia, serif;
        font-size: clamp(1.75rem, 5vw, 2.5rem);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        position: relative;

        /* each link fades + rises in, with staggered delay via --i */
        opacity: 0;
        transform: translateY(18px);
        transition:
            opacity 0.4s ease calc(var(--i) * 65ms + 0.2s),
            transform 0.4s ease calc(var(--i) * 65ms + 0.2s),
            color 0.2s;
    }

    /* underline sweep on hover */
    .mobile-link::after {
        content: "";
        position: absolute;
        bottom: -3px;
        left: 0;
        width: 0;
        height: 1px;
        background: #fff;
        transition: width 0.3s ease;
    }
    .mobile-link:hover::after {
        width: 100%;
    }
    .mobile-link:hover {
        color: #ccc;
    }

    .mobile-overlay.is-open .mobile-link {
        opacity: 1;
        transform: translateY(0);
    }

    .mobile-cta {
        margin-top: 0.75rem;
        font-family: system-ui, sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        background: #fff;
        color: #000 !important;
        padding: 1rem 2.5rem;
        border-radius: 2px;
        transition:
            background 0.2s,
            opacity 0.4s ease calc(var(--i) * 65ms + 0.2s),
            transform 0.4s ease calc(var(--i) * 65ms + 0.2s) !important;
    }

    .mobile-cta::after {
        display: none;
    }
    .mobile-cta:hover {
        background: #e0e0e0 !important;
        color: #000 !important;
    }
</style>

<script>
    const toggle = document.getElementById("menu-toggle")!;
    const overlay = document.getElementById("mobile-overlay")!;
    const links = document.querySelectorAll(".mobile-link");

    let isOpen = false;

    function open() {
        isOpen = true;
        toggle.classList.add("is-open");
        overlay.classList.add("is-open");
        overlay.setAttribute("aria-hidden", "false");
        toggle.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
    }

    function close() {
        isOpen = false;
        toggle.classList.remove("is-open");
        overlay.classList.remove("is-open");
        overlay.setAttribute("aria-hidden", "true");
        toggle.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
    }

    toggle.addEventListener("click", () => (isOpen ? close() : open()));
    links.forEach((l) => l.addEventListener("click", close));
    document.addEventListener("keydown", (e) => e.key === "Escape" && close());
</script>
